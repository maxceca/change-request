# ─── Snowflake ─────────────────────────────────────────────────────────────
# Formato de SF_ACCOUNT: <orgname>-<accountname>  (ej: myorg-myaccount)
SF_ACCOUNT=
SF_USER=
SF_PASSWORD=
SF_WAREHOUSE=
SF_DATABASE=
SF_SCHEMA=
SF_TABLE=

# ─── Microsoft Graph API ────────────────────────────────────────────────────
# App Registration en Azure AD del tenant de CenSystems
# Permisos necesarios (Application permissions, no Delegated):
#   - Mail.Send
#   - Files.ReadWrite.All (o Sites.ReadWrite.All si el Excel está en SharePoint)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_EMAIL=noreply@censystems.com.mx

# ─── Excel en OneDrive / SharePoint ─────────────────────────────────────────
# Para obtener EXCEL_DRIVE_ID y EXCEL_FILE_ID:
#   1. Abre el archivo Excel en OneDrive/SharePoint en el navegador
#   2. Copia la URL — contiene el driveId y el itemId en el path
#   O usa Graph Explorer: https://developer.microsoft.com/en-us/graph/graph-explorer
#     GET /v1.0/me/drive/root/children  →  busca el archivo y copia su id
EXCEL_DRIVE_ID=
EXCEL_FILE_ID=
# Nombre exacto de la Tabla de Excel (no la hoja, sino la Tabla formateada dentro de la hoja)
EXCEL_TABLE_NAME=TablaProyecciones
